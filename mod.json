{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "omgrod.rods-fangame-tools",
	"name": "Rod's Fangame Tools",
	"version": "v1.0.0",
	"developer": "OmgRod",
	"description": "",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0",
		"alphalaneous.editortab_api": ">=2.1.5",
		"legowiifun.unlisted_objects_in_editor": {
			"required": false,
			"version": ">=1.4.5"
		}
	},
	"settings": {
		"levels-title": {
			"name": "Levels",
			"type": "title"
		},
		"copy-main-levels": {
			"name": "Copy Main Levels",
			"type": "bool",
			"default": true
		},
		"copy-level-string": {
			"name": "Copy Level String",
			"type": "bool",
			"default": true
		},
		"level-copy-type": {
			"name": "Level Copy Type",
			"type": "string",
			"default": "Encoded",
			"one-of": ["Encoded", "Decoded"]
		}
	}
